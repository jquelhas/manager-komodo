# Alertmanager config TEMPLATE. Rendered at startup by the `alertmanager-init` service
# (os.path.expandvars) into the `alertmanager-config` volume — Alertmanager reads the rendered
# file. Every deployment-specific value is a ${VAR} sourced from .env (see .env.example); nothing
# secret lives in git. To change SMTP: edit .env, then
#   docker compose up -d alertmanager-init && docker compose restart alertmanager
global:
  resolve_timeout: 5m
  smtp_smarthost: '${SMTP_SMARTHOST}'
  smtp_from: '${SMTP_FROM}'
  smtp_auth_username: '${SMTP_AUTH_USERNAME}'
  smtp_auth_password: '${SMTP_AUTH_PASSWORD}'
  smtp_require_tls: ${SMTP_REQUIRE_TLS}

route:
  receiver: email
  group_by: ['alertname', 'host', 'server']
  group_wait: 30s          # hold a new group briefly to batch related alerts
  group_interval: 5m       # how often to send updates for an existing group
  repeat_interval: 4h      # re-notify an unresolved alert this often
  # Add `routes:` here later to split by severity/scope (e.g. critical -> a second inbox).

receivers:
  - name: email
    email_configs:
      - to: '${ALERT_EMAIL_TO}'
        send_resolved: true    # also e-mail when an alert clears
