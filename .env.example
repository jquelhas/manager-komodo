# Domínio público (Let's Encrypt via TLS-ALPN-01)
PUBLIC_DOMAIN=komodo.segcore.eu
ACME_EMAIL=admin@segcore.eu
# IP público do host. O entrypoint público binda este IP específico (não 0.0.0.0) para
# coexistir com o entrypoint interno em 100.64.0.1:443 (o mesmo porto 443 em IPs diferentes).
PUBLIC_IP=145.239.197.177

# CA interna (step-ca)
STEPCA_NAME=Quelhas & Fernandes, Lda
# Password que cifra as chaves da CA — gerar: openssl rand -hex 32
STEPCA_INIT_PASSWORD=change-me

# Grafana initial admin password — generate: openssl rand -hex 24
GRAFANA_ADMIN_PASSWORD=change-me

# Komodo Core + Mongo
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=change-me          # generate: openssl rand -hex 24
KOMODO_INIT_ADMIN_USERNAME=jferreira
KOMODO_INIT_ADMIN_PASSWORD=change-me        # generate: openssl rand -hex 24
KOMODO_WEBHOOK_SECRET=change-me             # generate: openssl rand -hex 32
KOMODO_JWT_SECRET=change-me                 # generate: openssl rand -hex 32

# Komodo API key/secret used by the provisioning service to auto-register onboarded hosts as
# Komodo Servers (POST /write/CreateServer). Generate once in the Komodo UI
# (Settings -> API Keys -> New) and paste both. Stays on the manager only; never sent to hosts.
KOMODO_API_KEY=change-me
KOMODO_API_SECRET=change-me

# Headplane — Headscale web UI (internal only: headplane/tailscale.apps.internal via step-ca).
# Injected as HEADPLANE_* env overrides into config.yaml (HEADPLANE_<SECTION>__<KEY>).
HEADPLANE_COOKIE_SECRET=change-me        # generate: openssl rand -hex 16 (MUST be exactly 32 chars)
HEADPLANE_API_KEY=change-me              # docker exec manager-headscale headscale apikeys create --expiration 87600h
HEADPLANE_BASE_URL=https://headplane.apps.internal   # UI served under /admin

# Alerting — Alertmanager SMTP (the single notification hub for vmalert + Komodo alerts).
# These are rendered into the Alertmanager config at startup by the alertmanager-init service.
SMTP_SMARTHOST=smtp.example.com:587      # host:port of the mail relay (587 = STARTTLS)
SMTP_FROM=alerts@segcore.eu              # envelope/from address
SMTP_AUTH_USERNAME=change-me             # SMTP auth user (often the same as SMTP_FROM)
SMTP_AUTH_PASSWORD=change-me             # SMTP auth password (secret; keep out-of-band)
SMTP_REQUIRE_TLS=true                    # true for STARTTLS (587); false only if the relay needs it
ALERT_EMAIL_TO=jferreira@wavecom.pt      # where alert e-mails are delivered

# PGHero — PostgreSQL fleet analysis (pghero.apps.internal, internal only via step-ca).
# PGHERO_DB_USER / PGHERO_DB_PASSWORD are the read-only monitoring role that must exist on EACH app
# host's Postgres (CREATE ROLE monitor LOGIN PASSWORD '...'; GRANT pg_monitor TO monitor;) — see
# docs/pghero-host-setup.md. Use the SAME role+password on every host so the manager keeps a single
# secret. Prefer a URL-safe password (no @ / : / spaces); it is placed in a connection URL.
PGHERO_DB_USER=monitor                       # read-only role name on the app hosts
PGHERO_DB_PASSWORD=change-me                 # its password (must match the role on the hosts)
PGHERO_DB_PATTERN=gims_%                     # LIKE pattern for which databases to analyse per host
# PGHero's own history store (pghero-postgres) — holds query/space-stats snapshots (writable).
PGHERO_HISTORY_DB_USERNAME=pghero
PGHERO_HISTORY_DB_PASSWORD=change-me         # generate: openssl rand -hex 24
# UI HTTP basic-auth (the UI is mesh-only, but keep it behind auth anyway).
PGHERO_USERNAME=admin
PGHERO_PASSWORD=change-me                    # generate: openssl rand -hex 24

# Backups to S3 (scripts/backup-manager.sh). S3-compatible (OVH Object Storage / AWS / ...).
# CRITICAL: BACKUP_MASTER_KEY encrypts the archive AND is stored inside .env, which is inside
# the archive — so keep a copy OUT-OF-BAND (password manager). Restore needs it from the env.
BACKUP_MASTER_KEY=change-me                 # generate: openssl rand -hex 32
BACKUP_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net   # object-storage S3 endpoint URL
BACKUP_S3_REGION=gra                        # optional (region name), else leave blank
BACKUP_S3_BUCKET=change-me                  # bucket name (may be shared with GIMSv2)
BACKUP_S3_PREFIX=manager-komodo             # key prefix inside the bucket
BACKUP_S3_ACCESS_KEY=change-me
BACKUP_S3_SECRET_KEY=change-me
# Retention is enforced by the BUCKET, not the script: Object Lock (COMPLIANCE, 30d) makes
# objects immutable, and a Lifecycle rule expires them at 30d. Set both on the bucket once
# (see docs/OPS or the commands used in setup). No client-side prune / no RETENTION_DAYS var.

# Documentado para o passo da mesh (não usado ao 4.1):
# TAILSCALE_IP=100.64.0.1
# INTERNAL_DOMAIN=apps.internal
