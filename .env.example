# Domínio público (Let's Encrypt via TLS-ALPN-01)
PUBLIC_DOMAIN=komodo.segcore.eu
ACME_EMAIL=admin@segcore.eu
# IP público do host. O entrypoint público binda este IP específico (não 0.0.0.0) para
# coexistir com o entrypoint interno em 100.64.0.1:443 (o mesmo porto 443 em IPs diferentes).
PUBLIC_IP=145.239.197.177

# CA interna (step-ca)
STEPCA_NAME=Quelhas & Fernandes, Lda
# Password que cifra as chaves da CA — gerar: openssl rand -hex 32
STEPCA_INIT_PASSWORD=change-me

# Grafana initial admin password — generate: openssl rand -hex 24
GRAFANA_ADMIN_PASSWORD=change-me

# Komodo Core + Mongo
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=change-me          # generate: openssl rand -hex 24
KOMODO_INIT_ADMIN_USERNAME=jferreira
KOMODO_INIT_ADMIN_PASSWORD=change-me        # generate: openssl rand -hex 24
KOMODO_WEBHOOK_SECRET=change-me             # generate: openssl rand -hex 32
KOMODO_JWT_SECRET=change-me                 # generate: openssl rand -hex 32

# Backups to S3 (scripts/backup-manager.sh). S3-compatible (OVH Object Storage / AWS / ...).
# CRITICAL: BACKUP_MASTER_KEY encrypts the archive AND is stored inside .env, which is inside
# the archive — so keep a copy OUT-OF-BAND (password manager). Restore needs it from the env.
BACKUP_MASTER_KEY=change-me                 # generate: openssl rand -hex 32
BACKUP_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net   # object-storage S3 endpoint URL
BACKUP_S3_REGION=gra                        # optional (region name), else leave blank
BACKUP_S3_BUCKET=change-me                  # bucket name (may be shared with GIMSv2)
BACKUP_S3_PREFIX=manager-komodo             # key prefix inside the bucket
BACKUP_S3_ACCESS_KEY=change-me
BACKUP_S3_SECRET_KEY=change-me
# Retention is enforced by the BUCKET, not the script: Object Lock (COMPLIANCE, 30d) makes
# objects immutable, and a Lifecycle rule expires them at 30d. Set both on the bucket once
# (see docs/OPS or the commands used in setup). No client-side prune / no RETENTION_DAYS var.

# Documentado para o passo da mesh (não usado ao 4.1):
# TAILSCALE_IP=100.64.0.1
# INTERNAL_DOMAIN=apps.internal
